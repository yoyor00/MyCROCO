#!/bin/bash
####################################################
#        MS3DVAR COMPILATION JOB                   #
####################################################
#
# This script compiles MS3DVAR data assimilation system
# Similar to CROCO's jobcomp but adapted for MS3DVAR
#
# Usage examples:
#   ./jobcomp                    # Build all variants (default)
#   ./jobcomp all                # Build all variants (explicit)
#   ./jobcomp lr                 # Build LR variant only
#   ./jobcomp lr ms              # Build LR and MS variants
#   ./jobcomp mr --clean         # Build MR variant with clean
#   ./jobcomp --jobs 4 lr mr     # Build LR and MR with 4 jobs
#   ./jobcomp lr mr filter --clean --jobs 4 # Build 3 variants with options
#   ./jobcomp --jobs 4 all       # Build all variants with 4 jobs
#
# Alternative syntax (explicit --variant flag):
#   ./jobcomp --variant lr       # Build single variant (old syntax)
#
# Environment variables:
#   MS3DVAR_VARIANT      : variant to build (lr, mr, filter, ms)
#   MS3DVAR_FC           : Fortran compiler (default: gfortran)
#   MS3DVAR_FFLAGS       : compilation flags
#   MS3DVAR_NETCDFLIB    : NetCDF library path
#   MS3DVAR_NETCDFINC    : NetCDF include path
#   MS3DVAR_NPROCS       : number of parallel compilation jobs
#   CROCO_SRC            : CROCO source directory
#   MS3DVAR_SRC          : MS3DVAR source directory
#

####################################################
# BEGIN OF USER'S MODIFICATIONS
####################################################

# Default: build all variants (set to specific variant like "lr" to change default)
VARIANT="all"

# CROCO source directory (default: ../../OCEAN from work dir)
SOURCE1="../../OCEAN"

# MS3DVAR source directory (default: .. from work dir, i.e., ASSIM/MS3DVAR)
SOURCE2="."

# Compiler
FC="gfortran"

# NetCDF directories (using nf-config if available)
if command -v nf-config &> /dev/null; then
    NETCDFLIB="$(nf-config --flibs)"
    NETCDFINC="-I$(nf-config --includedir)"
else
    # Fallback to conda3/perso paths (adjust as needed)
    NETCDFINC="-I$HOME/Soft/conda3-perso/include"
    NETCDFLIB="-L$HOME/Soft/conda3-perso/lib -lnetcdff -lnetcdf"
fi

# Number of parallel make jobs
NPROCS=1

# Module to load (leave empty if not needed)
#MODULE_LOAD="my_module"

####################################################
# END OF USER'S MODIFICATIONS
####################################################

# EDIT ALL WHAT FOLLOWS AT YOUR OWN RISKS

# Function to display help
function show_help() {
    echo "---------------------------------------------------------------------"
    echo "JOBCOMP script to compile MS3DVAR data assimilation system"
    echo "---------------------------------------------------------------------"
    echo "Usage: $0 [OPTIONS] [VARIANT...]"
    echo "   or: $0 [VARIANT...] [OPTIONS]"
    echo ""
    echo "Arguments:"
    echo "  VARIANT...                  Variant(s) to build: lr, mr, filter, ms, all"
    echo "                              Multiple variants can be specified"
    echo "                              Can be placed before or after options"
    echo "                              (default: all if not specified)"
    echo ""
    echo "Options:"
    echo "  -h, --help                  Show this help message and exit"
    echo "  --variant <name>            Alternative way to specify single variant"
    echo "  --croco-src <path>          CROCO source directory (default: ../../OCEAN)"
    echo "  --ms3dvar-src <path>        MS3DVAR source directory (default: ..)"
    echo "  --fc <compiler>             Fortran compiler (default: gfortran)"
    echo "  --fflags <flags>            Compilation flags"
    echo "  --netcdf-inc <path>         NetCDF include directory"
    echo "  --netcdf-lib <libs>         NetCDF libraries"
    echo "  --jobs <n>                  Number of parallel make jobs (default: 1)"
    echo "  --no-module                 Don't load any module"
    echo "  --module <name>             Module to load (default: conda3/perso)"
    echo "  --clean                     Clean before building"
    echo ""
    echo "Examples:"
    echo "  $0                          # Build all variants (default)"
    echo "  $0 all                      # Build all variants (explicit)"
    echo "  $0 lr                       # Build only LR variant"
    echo "  $0 lr ms                    # Build LR and MS variants"
    echo "  $0 mr --clean               # Variant first, then options"
    echo "  $0 --clean mr filter        # Options first, variants at end"
    echo "  $0 --jobs 4 lr mr ms        # Multiple options and variants"
    echo "  $0 lr mr filter --clean     # Variants first, options at end"
    echo "  $0 --jobs 4 all             # Build all variants with 4 jobs"
    echo ""
}

# Variables
BUILD_ALL=0
DO_CLEAN=0
NO_MODULE=0
DEBUG=0
POSITIONAL_VARIANTS=()

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        --variant)
            VARIANT="$2"
            shift 2
            ;;
        --fc)
            FC="$2"
            shift 2
            ;;
        --fflags)
            FFLAGS="$2"
            shift 2
            ;;
        --netcdf-inc)
            NETCDFINC="$2"
            shift 2
            ;;
        --netcdf-lib)
            NETCDFLIB="$2"
            shift 2
            ;;
        --jobs)
            NPROCS="$2"
            shift 2
            ;;
        --module)
            MODULE_LOAD="$2"
            shift 2
            ;;
        --no-module)
            NO_MODULE=1
            shift
            ;;
        --debug)
            DEBUG=1
            shift
            ;;
        --croco-src)
            SOURCE1="$2"
            shift 2
            ;;
        --ms3dvar-src)
            SOURCE2="$2"
            shift 2
            ;;
        --clean)
            DO_CLEAN=1
            shift
            ;;
        -*)
            echo "Unknown option: $1"
            show_help
            exit 1
            ;;
        *)
            # Positional argument (variant name)
            POSITIONAL_VARIANTS+=("$1")
            shift
            ;;
    esac
done

# Determine variants to build
if [ ${#POSITIONAL_VARIANTS[@]} -gt 0 ]; then
    # Positional variants provided - build these specific variants
    BUILD_ALL=1  # We'll handle multiple variants
    VARIANTS_TO_BUILD=("${POSITIONAL_VARIANTS[@]}")
elif [ -n "$VARIANT" ] && [ "$VARIANT" != "all" ]; then
    # --variant flag used with specific variant
    VARIANTS_TO_BUILD=("$VARIANT")
else
    # No specific variants, use default behavior
    VARIANT="${VARIANT:-all}"
fi

# Environment variable overrides
[ -n "$MS3DVAR_VARIANT" ] && VARIANT="$MS3DVAR_VARIANT"
[ -n "$MS3DVAR_FC" ] && FC="$MS3DVAR_FC"
[ -n "$MS3DVAR_FFLAGS" ] && FFLAGS="$MS3DVAR_FFLAGS"
[ -n "$MS3DVAR_NETCDFINC" ] && NETCDFINC="$MS3DVAR_NETCDFINC"
[ -n "$MS3DVAR_NETCDFLIB" ] && NETCDFLIB="$MS3DVAR_NETCDFLIB"
[ -n "$MS3DVAR_NPROCS" ] && NPROCS="$MS3DVAR_NPROCS"

# Set source directories (allow override via env variables)
CROCO_SOURCE="${CROCO_SRC:-$SOURCE1}"
MS3DVAR_SOURCE="${MS3DVAR_SRC:-$SOURCE2}"

# Handle "all" variant
VARIANT_LOWER=$(echo "$VARIANT" | tr '[:upper:]' '[:lower:]')
if [ "$VARIANT_LOWER" = "all" ]; then
    BUILD_ALL=1
fi

# Validate variant
case "$VARIANT_LOWER" in
    lr|mr|filter|ms|all)
        ;;
    *)
        echo "ERROR: Invalid variant '$VARIANT'. Must be one of: lr, mr, filter, ms"
        exit 1
        ;;
esac

# Convert to uppercase for directory name
VARIANT_UPPER=$(echo "$VARIANT_LOWER" | tr '[:lower:]' '[:upper:]')

# Function to build a single variant
function build_variant() {
    local var_lower=$1
    local var_upper=$2
    local variant_dir="${var_upper}"

    # Convert relative source paths to absolute now (before cd into Compile subdir)
    [[ ! "${MS3DVAR_SOURCE}" = /* ]] && MS3DVAR_SOURCE="$(cd "${MS3DVAR_SOURCE}" && pwd)"
    [[ ! "${CROCO_SOURCE}" = /*   ]] && CROCO_SOURCE="$(cd "${CROCO_SOURCE}" && pwd)"

    echo ""
    echo "========================================================================"
    echo "Building MS3DVAR variant: ${var_upper}"
    echo "========================================================================"
    echo "Variant directory: ${variant_dir}"
    echo "CROCO source: ${CROCO_SOURCE}"
    echo "MS3DVAR source: ${MS3DVAR_SOURCE}"
    echo "Compiler: ${FC}"
    echo "NetCDF include: ${NETCDFINC}"
    echo "NetCDF library: ${NETCDFLIB}"
    echo "Parallel jobs: ${NPROCS}"
    echo ""

    # Check if variant directory exists
    if [ ! -d "${MS3DVAR_SOURCE}/${variant_dir}" ]; then
        echo "ERROR: Variant directory ${variant_dir} not found"
        return 1
    fi

    # Enter variant directory
    cd "${MS3DVAR_SOURCE}/${variant_dir}" || { echo "ERROR: Cannot enter ${MS3DVAR_SOURCE}/${variant_dir}"; return 1; }

    RUNDIR="$(pwd)"
    COMPILE_DIR="./Compile"
    SCRDIR=$COMPILE_DIR  # backward-compat alias

    # Clean scratch area
    echo "Preparing compilation directory..."
    rm -rf "$COMPILE_DIR"
    mkdir "$COMPILE_DIR"
    echo ""

    # Load module if needed
    if [ $NO_MODULE -eq 0 ] && [ -n "$MODULE_LOAD" ]; then
        echo "Loading module: ${MODULE_LOAD}"
        if command -v module &> /dev/null; then
            module load ${MODULE_LOAD} 2>/dev/null || true
        else
            echo "WARNING: 'module' command not found, skipping module load"
        fi
        echo ""
    fi

    # Check source files exist
    if [ ! -f ${CROCO_SOURCE}/main.F ]; then
        echo "ERROR: CROCO source files not found at ${CROCO_SOURCE}/"
        echo "Please specify the correct path with --croco-src /path/to/OCEAN"
        cd ..
        return 1
    fi

    if [ ! -d ${MS3DVAR_SOURCE}/COMMON ]; then
        echo "ERROR: MS3DVAR source files not found at ${MS3DVAR_SOURCE}/"
        echo "Please specify the correct path with --ms3dvar-src /path/to/MS3DVAR"
        cd ..
        return 1
    fi

    # Copy CROCO source files needed for MS3DVAR
    echo "Copying CROCO source files..."
    ls "${CROCO_SOURCE}/"*.F       > /dev/null 2>&1 && \cp "${CROCO_SOURCE}/"*.F   "$COMPILE_DIR"
    ls "${CROCO_SOURCE}/"*.F90     > /dev/null 2>&1 && \cp "${CROCO_SOURCE}/"*.F90 "$COMPILE_DIR"
    ls "${CROCO_SOURCE}/"*.h       > /dev/null 2>&1 && \cp "${CROCO_SOURCE}/"*.h   "$COMPILE_DIR"
    echo "CROCO sources copied"
    echo ""

    # Save CROCO's param.h as croco_ocean_param.h before variant files overwrite it.
    # MS3DVAR includes this (with MS3DVAR_GRID_PARAMS guard) to get the physics/tracer
    # parameters from the real CROCO param.h, avoiding duplication in croco_extra_params.h.
    \cp "${CROCO_SOURCE}/param.h" "${COMPILE_DIR}/croco_ocean_param.h"

    # Copy MS3DVAR common source files
    echo "Copying MS3DVAR common source files..."
    ls "${MS3DVAR_SOURCE}/COMMON/"*.F   > /dev/null 2>&1 && \cp "${MS3DVAR_SOURCE}/COMMON/"*.F   "$COMPILE_DIR"
    ls "${MS3DVAR_SOURCE}/COMMON/"*.F90 > /dev/null 2>&1 && \cp "${MS3DVAR_SOURCE}/COMMON/"*.F90 "$COMPILE_DIR"
    ls "${MS3DVAR_SOURCE}/COMMON/"*.h   > /dev/null 2>&1 && \cp "${MS3DVAR_SOURCE}/COMMON/"*.h   "$COMPILE_DIR"
    echo "MS3DVAR common sources copied"
    echo ""

    # Copy variant Makefile to compilation directory
    echo "Copying build system files..."
    \cp "${MS3DVAR_SOURCE}/${var_upper}/Makefile" "$COMPILE_DIR"
    echo "Build system copied"
    echo ""

    # Place modified Makefile.inc directly in Compile/.
    # The variant Makefile uses "include Makefile.inc" (same directory).
    echo "Configuring Makefile.inc..."
    \cp "${MS3DVAR_SOURCE}/Makefile.inc" "${COMPILE_DIR}/Makefile.inc"
    sed -i 's|^COMMON_DIR = .*|COMMON_DIR = .|' "${COMPILE_DIR}/Makefile.inc" 2>/dev/null || true
    sed -i 's|^CROCO_SRC = .*|CROCO_SRC = .|' "${COMPILE_DIR}/Makefile.inc" 2>/dev/null || true
    sed -i 's|^VPATH = .*|VPATH = .|' "${COMPILE_DIR}/Makefile.inc" 2>/dev/null || true
    echo "Makefile.inc configured"
    echo ""

    # Copy all variant-specific source files from MS3DVAR_SOURCE (the versioned source)
    echo "Copying variant-specific files..."
    ls "${MS3DVAR_SOURCE}/${var_upper}/"*.h   > /dev/null 2>&1 && \cp "${MS3DVAR_SOURCE}/${var_upper}/"*.h   "$COMPILE_DIR"
    ls "${MS3DVAR_SOURCE}/${var_upper}/"*.F   > /dev/null 2>&1 && \cp "${MS3DVAR_SOURCE}/${var_upper}/"*.F   "$COMPILE_DIR"
    ls "${MS3DVAR_SOURCE}/${var_upper}/"*.F90 > /dev/null 2>&1 && \cp "${MS3DVAR_SOURCE}/${var_upper}/"*.F90 "$COMPILE_DIR"
    echo "Configuration files copied"
    echo ""

    # Overwrite with user local files (if any)
    # WARNING Local dir. = ${MS3DVAR_SOURCE}/${var_upper}
    echo "Checking for user local files in $(pwd)..."
    ls *.F90   > /dev/null 2>&1 && \cp -f *.F90 "$COMPILE_DIR" && echo "  User .F90 files copied"
    ls *.F     > /dev/null 2>&1 && \cp -f *.F "$COMPILE_DIR" && echo "  User .F files copied"
    ls *.h     > /dev/null 2>&1 && \cp -f *.h "$COMPILE_DIR" && echo "  User .h files copied"
    ls *.h90   > /dev/null 2>&1 && \cp -f *.h90 "$COMPILE_DIR" && echo "  User .h90 files copied"
    ls Makefile > /dev/null 2>&1 && \cp -f Makefile "$COMPILE_DIR" && echo "  User Makefile override copied"
    echo ""

    # Build mpc preprocessor from CROCO source (needed by Makedefs suffix rules)
    echo "Building mpc preprocessor from CROCO source..."
    ${FC} -o ${COMPILE_DIR}/mpc ${CROCO_SOURCE}/mpc.F || { echo "ERROR: Failed to build mpc"; cd ..; return 1; }
    echo ""

    # Change to compilation directory
    cd "$COMPILE_DIR" || { echo "ERROR: Cannot enter compilation directory"; cd ..; return 1; }

    # Determine OS-based compiler settings (mirrors CROCO OCEAN jobcomp)
    OS_NAME=$(uname)
    LDFLAGS1="${NETCDFLIB}"
    CPPFLAGS1="${NETCDFINC}"
    if [[ $OS_NAME == Linux || $OS_NAME == Darwin ]]; then
        if [[ $FC == ifort || $FC == ifc ]]; then
            CPP1="cpp -traditional -DLinux -DIfort"
            CFT1="ifort"
            FFLAGS1="-O2 -mcmodel=medium -fno-alias -i4 -r8 -fp-model precise"
        elif [[ $FC == ifx ]]; then
            CPP1="cpp -traditional -DLinux -DIfort"
            CFT1="$FC"
            FFLAGS1="-O2 -mcmodel=medium -fno-alias -i4 -r8 -fp-model precise"
        elif [[ $FC == gfortran || $FC == gfortran-* ]]; then
            CPP1="cpp -traditional -DLinux"
            CFT1="$FC"
            if [ $DEBUG -eq 0 ] ; then
                FFLAGS1="-O2 -mcmodel=medium -fdefault-real-8 -fdefault-double-8 -std=legacy"
            else
                FFLAGS1="-g -fbacktrace -mcmodel=medium -fdefault-real-8 -fdefault-double-8 -std=legacy"
            fi
        elif [[ $FC == pgfortran || $FC == nvfortran ]]; then
            CPP1="cpp -traditional -DLinux -DXLF"
            CFT1="$FC"
            FFLAGS1="-g -fast -r8 -i4 -mcmodel=medium -Mbackslash"
        else
            echo "WARNING: Unknown Fortran compiler '$FC', using gfortran defaults"
            CPP1="cpp -traditional -DLinux"
            CFT1="$FC"
            FFLAGS1="-O2"
        fi
    else
        echo "ERROR: Unsupported OS '$OS_NAME'. Only Linux and Darwin are supported."
        cd ../..
        return 1
    fi
    # User --fflags override takes priority
    [ -n "$FFLAGS" ] && FFLAGS1="$FFLAGS"
    # Add NetCDF include to compiler flags
    FFLAGS1="$FFLAGS1 ${NETCDFINC}"

    # Detect OpenMP (using testkeys.F from CROCO source, mirrors CROCO jobcomp)
    echo "Checking COMPILEOMP..."
    if $($CPP1 testkeys.F | grep -i -q openmpisdefined); then
        echo " => OpenMP activated"
        if [[ $FC == ifort || $FC == ifc ]]; then
            INTEL_VERSION=$(ifort --version 2>&1 | grep -oP "(\d+)" | head -n1)
            if [[ "$INTEL_VERSION" -gt 18 ]]; then
                FFLAGS1="$FFLAGS1 -qopenmp"
            else
                FFLAGS1="$FFLAGS1 -openmp"
            fi
        elif [[ $FC == ifx ]]; then
            FFLAGS1="$FFLAGS1 -qopenmp"
        else
            FFLAGS1="$FFLAGS1 -fopenmp"
        fi
    fi

    # Generate concrete Makedefs from the generic template
    # Substitutes $(CPP1), $(CFT1), $(FFLAGS1), $(LDFLAGS1), $(CPPFLAGS1)
    # with actual values determined above (same approach as CROCO OCEAN jobcomp).
    echo "Generating Makedefs from template..."
    rm -f Makedefs flags.tmp
    printf 's?$(FFLAGS1)?%s?g\n'   "$FFLAGS1"   >> flags.tmp
    printf 's?$(LDFLAGS1)?%s?g\n'  "$LDFLAGS1"  >> flags.tmp
    printf 's?$(CPP1)?%s?g\n'      "$CPP1"       >> flags.tmp
    printf 's?$(CFT1)?%s?g\n'      "$CFT1"       >> flags.tmp
    printf 's?$(CPPFLAGS1)?%s?g\n' "$CPPFLAGS1"  >> flags.tmp
    sed -f flags.tmp "${MS3DVAR_SOURCE}/Makedefs.generic" > Makedefs
    rm -f flags.tmp
    echo "Makedefs generated"
    echo ""

    # Build main MS3DVAR code
    echo "Building MS3DVAR main code..."
    echo "This may take several minutes..."
    echo ""

    # Re-introducing original croco dependence mechanism
    make depend

    # Build with make
    if [ $NPROCS -gt 1 ]; then
        make -j${NPROCS} all || { echo "ERROR: Make failed"; cd ../..; return 1; }
    else
        make all || { echo "ERROR: Make failed"; cd ../..; return 1; }
    fi

    # Find the executable
    EXE=$(find . -maxdepth 1 -type f -executable -name "ms*" -o -name "da_*" 2>/dev/null | head -1)

    # Copy executable back to variant directory
    if [ -n "$EXE" ]; then
        \cp "$EXE" "${RUNDIR}/"
        echo ""
        echo "Executable copied to ${RUNDIR}/$(basename $EXE)"
    fi

    echo ""
    echo "========================================================================"
    echo "MS3DVAR ${var_upper} built successfully!"
    if [ -n "$EXE" ]; then
        echo "Executable: $(basename $EXE)"
        echo "Location: ${RUNDIR}/$(basename $EXE)"
    fi
    echo "========================================================================"
    echo ""

    # Return to parent directory (MS3DVAR root)
    cd ../..

    return 0
}

# Main execution
echo "========================================================================"
echo "MS3DVAR Compilation Script"
echo "========================================================================"
echo "Operating system: $(uname)"
echo "Date: $(date)"
echo ""

# Get script directory (MS3DVAR root)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || { echo "ERROR: Cannot access script directory"; exit 1; }

echo "MS3DVAR directory: ${SCRIPT_DIR}"
echo ""

if [ ${#VARIANTS_TO_BUILD[@]} -gt 0 ]; then
    # Build specific list of variants
    echo "Building ${#VARIANTS_TO_BUILD[@]} variant(s): ${VARIANTS_TO_BUILD[*]}"
    echo ""

    FAILED_VARIANTS=""

    for var in "${VARIANTS_TO_BUILD[@]}"; do
        var_lower=$(echo "$var" | tr '[:upper:]' '[:lower:]')
        var_upper=$(echo "$var" | tr '[:lower:]' '[:upper:]')

        # Validate variant
        case "$var_lower" in
            lr|mr|filter|ms)
                ;;
            *)
                echo "ERROR: Invalid variant '$var'. Must be one of: lr, mr, filter, ms"
                FAILED_VARIANTS="${FAILED_VARIANTS} ${var_upper}(invalid)"
                continue
                ;;
        esac

        if ! build_variant "$var_lower" "$var_upper"; then
            FAILED_VARIANTS="${FAILED_VARIANTS} ${var_upper}"
        fi
    done

    echo ""
    echo "========================================================================"
    echo "Build Summary"
    echo "========================================================================"
    if [ -z "$FAILED_VARIANTS" ]; then
        echo "All requested variants built successfully!"
        echo ""
        echo "Executables:"
        for var in "${VARIANTS_TO_BUILD[@]}"; do
            var_upper=$(echo "$var" | tr '[:lower:]' '[:upper:]')
            EXE=$(find ${var_upper} -maxdepth 1 -type f -executable -name "ms*" -o -name "da_*" 2>/dev/null | head -1)
            if [ -n "$EXE" ]; then
                echo "  ${var_upper}: $(basename $EXE)"
            fi
        done
        exit 0
    else
        echo "Some variants failed to build:${FAILED_VARIANTS}"
        exit 1
    fi
elif [ $BUILD_ALL -eq 1 ]; then
    # Build all 4 variants
    echo "Building all 4 variants sequentially..."
    echo ""

    FAILED_VARIANTS=""

    for var in lr mr filter ms; do
        var_upper=$(echo "$var" | tr '[:lower:]' '[:upper:]')
        if ! build_variant "$var" "$var_upper"; then
            FAILED_VARIANTS="${FAILED_VARIANTS} ${var_upper}"
        fi
    done

    echo ""
    echo "========================================================================"
    echo "Build Summary"
    echo "========================================================================"
    if [ -z "$FAILED_VARIANTS" ]; then
        echo "All variants built successfully!"
        echo ""
        echo "Executables:"
        for var in lr mr filter ms; do
            var_upper=$(echo "$var" | tr '[:lower:]' '[:upper:]')
            EXE=$(find ${var_upper} -maxdepth 1 -type f -executable -name "ms*" -o -name "da_*" 2>/dev/null | head -1)
            if [ -n "$EXE" ]; then
                echo "  ${var_upper}: $(basename $EXE)"
            fi
        done
        exit 0
    else
        echo "Some variants failed to build:${FAILED_VARIANTS}"
        exit 1
    fi
else
    # Build single variant
    if ! build_variant "$VARIANT_LOWER" "$VARIANT_UPPER"; then
        echo ""
        echo "Build failed for variant ${VARIANT_UPPER}"
        exit 1
    fi
    exit 0
fi
